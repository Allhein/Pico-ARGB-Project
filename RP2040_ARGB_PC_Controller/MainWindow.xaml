<Window x:Class="PicoARGBControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PicoARGBControl"
        mc:Ignorable="d"
        Title="Pico ARGB Controller" Height="760" Width="1280" MinHeight="720" MinWidth="1180"
        Background="{StaticResource AppBackgroundBrush}" FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="AnimatedRGBBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0.0" Color="#00F5D4" x:Name="Stop1"/>
            <GradientStop Offset="0.52" Color="#43A5FF" x:Name="Stop2"/>
            <GradientStop Offset="1.0" Color="#B15CFF" x:Name="Stop3"/>
        </LinearGradientBrush>

        <Storyboard x:Key="RGBAnimation" RepeatBehavior="Forever">
            <ColorAnimation Storyboard.TargetName="Stop1" Storyboard.TargetProperty="Color"
                            From="#00F5D4" To="#B15CFF" Duration="0:0:2.4" AutoReverse="True"/>
            <ColorAnimation Storyboard.TargetName="Stop2" Storyboard.TargetProperty="Color"
                            From="#43A5FF" To="#00F5D4" Duration="0:0:2.4" AutoReverse="True"/>
            <ColorAnimation Storyboard.TargetName="Stop3" Storyboard.TargetProperty="Color"
                            From="#B15CFF" To="#43A5FF" Duration="0:0:2.4" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="14">
        <Border x:Name="RootFrame"
                BorderBrush="{StaticResource AnimatedRGBBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Background="#05070B">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="10" Opacity="0.45"/>
            </Border.Effect>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource NeonCard}" Padding="16" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="LogoRing"
                                Width="62" Height="62"
                                CornerRadius="8"
                                BorderBrush="{StaticResource AnimatedRGBBrush}"
                                BorderThickness="1"
                                Background="#0A0E16"
                                Padding="7"
                                Margin="0,0,14,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#43A5FF" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                            <Image x:Name="RaspberryLogo"
                                   Source="pack://application:,,,/Assets/Raspberry_logo.png"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pico ARGB Controller" FontSize="28" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="RP2040 HID lighting control" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="1,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="2"
                            x:Name="StatusPill"
                            CornerRadius="8"
                            Background="#111723"
                            BorderBrush="#344055"
                            BorderThickness="1"
                            Padding="14,10"
                            MinWidth="230"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#FF5D73" Margin="0,0,10,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#FF5D73" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <StackPanel>
                                <TextBlock x:Name="lblStatus" Text="Desconectado" Foreground="#FF8A9A" FontWeight="SemiBold"/>
                                <TextBlock x:Name="lblHint" Text="Esperando conexión..." Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource NeonCard}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Lighting Modes" Style="{StaticResource PanelTitleText}"/>
                            <TextBlock Text="Choose the active firmware effect." Style="{StaticResource CaptionText}" Margin="0,3,0,14"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <StackPanel x:Name="ModesPanel" Orientation="Vertical"/>

                                <Border Margin="0,14,0,0" Padding="12" CornerRadius="8" Background="#0B1019" BorderBrush="#263044" BorderThickness="1">
                                    <StackPanel x:Name="ModeParamsPanel" Orientation="Vertical">
                                        <StackPanel x:Name="StaticParamsPanel" Visibility="Collapsed">
                                            <TextBlock Text="Static Color" Style="{StaticResource PanelTitleText}" FontSize="13"/>
                                            <TextBlock Text="Set the base color used by static, music pulse and color-aware effects." Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>

                                            <Border x:Name="StaticColorPreview" Height="72" CornerRadius="8" BorderBrush="#556276" BorderThickness="1" Margin="0,0,0,10">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#43A5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.35"/>
                                                </Border.Effect>
                                            </Border>

                                            <TextBlock Text="Red" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldRed" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblRed" Text="0" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Green" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldGreen" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblGreen" Text="255" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Blue" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldBlue" Minimum="0" Maximum="255" ValueChanged="RgbSlider_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblBlue" Text="255" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <UniformGrid Columns="4" Margin="0,0,0,10">
                                                <Button Tag="#FF0000" ToolTip="Red" Click="QuickColor_Click" Margin="0,0,6,6" Height="28" Background="#FF0000" BorderBrush="#FF8080"/>
                                                <Button Tag="#00FF00" ToolTip="Green" Click="QuickColor_Click" Margin="0,0,6,6" Height="28" Background="#00FF00" BorderBrush="#80FF80"/>
                                                <Button Tag="#0000FF" ToolTip="Blue" Click="QuickColor_Click" Margin="0,0,6,6" Height="28" Background="#0000FF" BorderBrush="#8080FF"/>
                                                <Button Tag="#00FFFF" ToolTip="Cyan" Click="QuickColor_Click" Margin="0,0,0,6" Height="28" Background="#00FFFF" BorderBrush="#80FFFF"/>
                                                <Button Tag="#FF00FF" ToolTip="Magenta" Click="QuickColor_Click" Margin="0,0,6,0" Height="28" Background="#FF00FF" BorderBrush="#FF80FF"/>
                                                <Button Tag="#FFFF00" ToolTip="Yellow" Click="QuickColor_Click" Margin="0,0,6,0" Height="28" Background="#FFFF00" BorderBrush="#FFFF80"/>
                                                <Button Tag="#FFFFFF" ToolTip="White" Click="QuickColor_Click" Margin="0,0,6,0" Height="28" Background="#FFFFFF" BorderBrush="#FFFFFF"/>
                                                <Button Tag="#FF8000" ToolTip="Orange" Click="QuickColor_Click" Margin="0" Height="28" Background="#FF8000" BorderBrush="#FFC080"/>
                                            </UniformGrid>

                                            <TextBlock Text="Advanced HEX" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="HEX" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox Grid.Column="1" x:Name="tbStaticHex" Text="#FF00D4FF" TextChanged="TbStaticHex_TextChanged"/>
                                            </Grid>
                                            <Button Content="Apply Color" Margin="0,10,0,0" Click="BtnSendMode_Click" Style="{StaticResource NeonButton}"/>
                                        </StackPanel>

                                        <StackPanel x:Name="MusicParamsPanel" Visibility="Collapsed">
                                            <TextBlock Text="Audio Meter" Style="{StaticResource PanelTitleText}" FontSize="13"/>
                                            <TextBlock Text="RMS, peak and auto gain drive the firmware audio meter." Style="{StaticResource CaptionText}" Margin="0,2,0,10"/>

                                            <TextBlock Text="Audio source" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" x:Name="cmbAudioSource" SelectionChanged="AudioSource_SelectionChanged" SelectedIndex="1"
                                                          Background="{StaticResource FieldBackgroundBrush}"
                                                          Foreground="#EEF3FF">
                                                    <ComboBox.Resources>
                                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0B1019"/>
                                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#0B1019"/>
                                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#15304B"/>
                                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                                                    </ComboBox.Resources>
                                                    <ComboBoxItem Content="Disabled"/>
                                                    <ComboBoxItem Content="System Audio"/>
                                                    <ComboBoxItem Content="Microphone"/>
                                                </ComboBox>
                                                <TextBlock Grid.Column="1" x:Name="lblAudioStatus" Text="Audio detenido" Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" x:Name="chkMusic" Checked="ChkMusic_Checked" Unchecked="ChkMusic_Unchecked" Content="Active" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <ProgressBar Grid.Column="1" x:Name="pbLevel" Maximum="100" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" x:Name="lblLevel" Text="0" Foreground="White" Width="32" TextAlignment="Right" Margin="8,0,0,0"/>
                                            </Grid>

                                            <CheckBox x:Name="chkIntensityColors" Content="Colores por intensidad global" IsChecked="True" Checked="MusicStyle_Changed" Unchecked="MusicStyle_Changed" Margin="0,0,0,10"/>

                                            <TextBlock Text="Sensitivity" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldSensitivity" Minimum="50" Maximum="300" Value="200" ValueChanged="MusicTuning_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblSensitivity" Text="200%" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Max intensity" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldMaxIntensity" Minimum="50" Maximum="100" Value="80" ValueChanged="MusicTuning_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblMaxIntensity" Text="80" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Smoothing" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldSmoothing" Minimum="0" Maximum="95" Value="45" ValueChanged="MusicTuning_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblSmoothing" Text="45%" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>

                                            <TextBlock Text="Decay" Style="{StaticResource CaptionText}"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider Grid.Column="0" x:Name="sldDecay" Minimum="0" Maximum="95" Value="82" ValueChanged="MusicTuning_ValueChanged"/>
                                                <TextBlock Grid.Column="1" x:Name="lblDecay" Text="82%" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel x:Name="NoParamsPanel" Visibility="Collapsed">
                                            <TextBlock Text="No extra parameters" Style="{StaticResource PanelTitleText}" FontSize="13"/>
                                            <TextBlock Text="This effect is controlled by mode and global brightness." Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Margin="0,14,0,0" Padding="12" CornerRadius="8" Background="#0B1019" BorderBrush="#263044" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Device" Style="{StaticResource PanelTitleText}" FontSize="13"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="VID" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="txtVid" Text="20A0" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="2" Text="PID" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="3" x:Name="txtPid" Text="423D"/>
                                </Grid>
                                <Button x:Name="btnConnect" Click="BtnConnect_Click" Margin="0,10,0,0" Style="{StaticResource NeonButton}">Conectar</Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource NeonCard}" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Live Preview" FontSize="20" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="Visual estimate of the ARGB fan strip behavior." Style="{StaticResource CaptionText}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="8" BorderBrush="#2B354B" BorderThickness="1" Background="#0B1019" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Assets/RP2040.png" Width="88" Height="48" Stretch="Uniform" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Pico RP2040" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="GPIO 0 ARGB" Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,4">
                            <Border Margin="8" CornerRadius="8" Background="#0A0F17" BorderBrush="#263044" BorderThickness="1" Padding="12">
                                <local:RGBFanControl x:Name="FanTL" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Margin="8" CornerRadius="8" Background="#0A0F17" BorderBrush="#263044" BorderThickness="1" Padding="12">
                                <local:RGBFanControl x:Name="FanTR" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Margin="8" CornerRadius="8" Background="#0A0F17" BorderBrush="#263044" BorderThickness="1" Padding="12">
                                <local:RGBFanControl x:Name="FanBL" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Margin="8" CornerRadius="8" Background="#0A0F17" BorderBrush="#263044" BorderThickness="1" Padding="12">
                                <local:RGBFanControl x:Name="FanBR" Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2" CornerRadius="8" Background="#0B1019" BorderBrush="#263044" BorderThickness="1" Padding="12" Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Global Brightness" Foreground="White" FontWeight="SemiBold"/>
                                    <TextBlock Text="0-100% UI. 100% equals the calibrated 90% safe firmware limit." Style="{StaticResource CaptionText}" Margin="0,2,0,6"/>
                                    <Slider x:Name="sldBrightness" Minimum="0" Maximum="100" Value="100" Width="320" HorizontalAlignment="Left"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="BrightnessSlider_ValueChanged"
                                            ToolTip="100% in the UI sends 90% to the firmware for safer LED current."/>

                                    <TextBlock Text="Effect Speed" Foreground="White" FontWeight="SemiBold" Margin="0,12,0,0"/>
                                    <TextBlock Text="Controls Rainbow, Breathing, Chase and Color Cycle." Style="{StaticResource CaptionText}" Margin="0,2,0,6"/>
                                    <Slider x:Name="sldEffectSpeed" Minimum="0" Maximum="100" Value="100" Width="320" HorizontalAlignment="Left"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="EffectSpeedSlider_ValueChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <TextBlock x:Name="lblBrightness" Text="100%" Foreground="White" FontSize="26" FontWeight="SemiBold" TextAlignment="Right"/>
                                    <TextBlock x:Name="lblBrightnessFirmware" Text="FW 90%" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextAlignment="Right"/>
                                    <TextBlock x:Name="lblEffectSpeed" Text="100%" Foreground="White" FontSize="18" FontWeight="SemiBold" TextAlignment="Right" Margin="0,18,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource NeonCard}" Margin="14,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Actions" Style="{StaticResource PanelTitleText}" FontSize="18"/>
                            <TextBlock Text="Send current state to the controller." Style="{StaticResource CaptionText}" Margin="0,3,0,14"/>
                            <Button x:Name="btnSaveApply" Click="BtnSaveApply_Click" Margin="0,0,0,8" Style="{StaticResource NeonButton}">Guardar y aplicar</Button>
                            <Button x:Name="btnSendMode" Click="BtnSendMode_Click" Style="{StaticResource NeonButton}">Enviar Modo</Button>
                        </StackPanel>

                        <Border Grid.Row="1" Margin="0,18,0,14" Padding="12" CornerRadius="8" Background="#0B1019" BorderBrush="#263044" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="HID Protocol" Style="{StaticResource PanelTitleText}" FontSize="13"/>
                                <TextBlock Text="PING, color, mode, off, music and brightness commands remain enabled." Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Activity Log" Style="{StaticResource PanelTitleText}" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" x:Name="txtLog" IsReadOnly="True"
                                     Background="#080B11"
                                     Foreground="#DDE6F7"
                                     BorderBrush="#263044"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
